;; Spirit in Physics — https://sip.etzhayyim.com
;; A cozy slow-life healing game. clj is the brain; Datomic/datalevin is the
;; world; Kotoba is the content-addressed durable + distributed layer; the GPU
;; work stays on kami-render (Rust/wgpu) via kami-engine-sdk-clj's render-IR.
;;
;; Stack rationale lives in docs/ARCHITECTURE.md. Source IP (story-bible) is the
;; single source of truth at ../../260208-spirit-in-physics.
{:paths ["src" "resources"]

 :deps {org.clojure/clojure       {:mvn/version "1.12.0"}
        com.cognitect/transit-clj {:mvn/version "1.0.333"}
        org.clojure/data.json     {:mvn/version "2.5.0"}      ; read story-bible JSON-LD
        ;; The engine SDK: scene/ecs/sim/db/render-IR contract over kami-render.
        gftd/kami-engine-sdk-clj  {:git/url "https://github.com/kotoba-lang/kami-engine-sdk-clj.git"
                                   :sha "47d8d86e8062054ec54d74eaddc5b0de034f1213"}
        ;; Work-agnostic 2D manga render commons (ADR-2606282100): STYLE-FIRST
        ;; CLIP-77 compose + image-gen client. sip.render injects work mappers.
        gftd/kami-mangaka-render-clj {:git/url "https://github.com/kotoba-lang/kami-mangaka-render-clj.git"
                                      :sha "2122c2a66c617d05bab21ed423b47b1956f826d3"}
        ;; Work-agnostic graphic-novel page composition (komawari + Java2D DTP).
        ;; sip.page wires sip.storyboard into page/compose-page!.
        gftd/kami-mangaka-page-clj   {:git/url "https://github.com/kotoba-lang/kami-mangaka-page-clj.git"
                                      :sha "06f00dcea143f223b5a33de5bf781536fd4a2fce"}}

 :aliases
 {;; ----- JVM authoring: build the water-city world → datalevin → snapshot ----
  :datomic   {:extra-deps {datalevin/datalevin {:mvn/version "0.9.22"}}}

  :dev       {:extra-paths ["dev" "examples"]
              :extra-deps  {datalevin/datalevin          {:mvn/version "0.9.22"}
                            org.clojure/tools.namespace  {:mvn/version "1.5.0"}}
              :jvm-opts    ["--add-opens=java.base/java.nio=ALL-UNNAMED"
                            "--add-opens=java.base/sun.nio.ch=ALL-UNNAMED"]}

  ;; Build the portable snapshot served to the browser:
  ;;   clojure -M:datomic:build -m sip.world
  :build     {:extra-paths ["dev"]
              :main-opts   ["-m" "sip.world"]}

  ;; Compose / render / load manga panels from the story-bible anchors:
  ;;   clojure -M:datomic:render compose 02-02b
  ;;   clojure -M:datomic:render render  02-02b out.png   (needs image-gen @ :8100)
  ;;   clojure -M:datomic:render load    /tmp/sip-world
  :render    {:main-opts ["-m" "sip.render"]}

  ;; ----- Browser runtime (ClojureScript → kami-render WASM → WebGPU) ---------
  :shadow    {:extra-paths ["src"]
              :extra-deps  {thheller/shadow-cljs       {:mvn/version "2.28.20"}
                            org.clojure/clojurescript  {:mvn/version "1.11.132"}
                            org.clojure/core.async     {:mvn/version "1.6.681"}  ; kami.backend.browser
                            com.cognitect/transit-cljs {:mvn/version "0.8.280"}}
              :main-opts   ["-m" "shadow.cljs.devtools.cli"]}

  ;; ----- Pure logic tests (no GPU, no DB): session FSM, kokoro, awakening -----
  :test      {:extra-paths ["test"]
              :extra-deps  {io.github.cognitect-labs/test-runner
                            {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
              :main-opts   ["-m" "cognitect.test-runner"]}}}
